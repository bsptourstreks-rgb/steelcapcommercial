---
/**
 * World-class Footer
 * With hover animations and micro-interactions
 */
const footerSections = [
  {
    title: 'Facility Services',
    links: [
      { name: 'Facility Management', href: '#services' },
      { name: 'Renewable Energy', href: '#services' },
      { name: 'Property Maintenance', href: '#services' },
      { name: 'Commercial Cleaning', href: '#services' },
    ]
  },
  {
    title: 'IT Services',
    links: [
      { name: 'Managed IT Support', href: '#it-services' },
      { name: 'Cybersecurity', href: '#it-services' },
      { name: 'Cloud Solutions', href: '#it-services' },
      { name: 'Software Development', href: '#it-services' },
    ]
  },
  {
    title: 'Company',
    links: [
      { name: 'About Us', href: '#' },
      { name: 'Careers', href: '#' },
      { name: 'Blog', href: '#' },
      { name: 'Contact', href: '#contact' },
    ]
  },
  {
    title: 'Legal',
    links: [
      { name: 'Privacy Policy', href: '#' },
      { name: 'Terms of Service', href: '#' },
      { name: 'Cookie Policy', href: '#' },
      { name: 'Accessibility', href: '#' },
    ]
  },
];

const socialLinks = [
  {
    name: 'LinkedIn',
    svg: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`,
    href: '#'
  },
  {
    name: 'Twitter',
    svg: `<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3 .1 4 .5 0 0 .1 0 .1-.1-1-3-2-5-2-5 3.4 2.2 4.8 7 4.9 8.3-.3.1-.6.1-.9.1z"/>`,
    href: '#'
  },
  {
    name: 'Facebook',
    svg: `<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>`,
    href: '#'
  },
  {
    name: 'Instagram',
    svg: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
    href: '#'
  },
  {
    name: 'Email',
    svg: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
    href: 'mailto:contact@steelcapcommercial.com'
  },
];
---

<footer class="relative overflow-hidden" style="background: linear-gradient(135deg, #d4d4d8 0%, #e4e4e7 30%, #f4f4f5 50%, #e4e4e7 70%, #d4d4d8 100%);">
  <!-- Pure metallic silver mesh overlay -->
  <div class="absolute inset-0 opacity-15" style="background-image: repeating-linear-gradient(0deg, #a1a1aa 0px 1px, transparent 1px 3px), repeating-linear-gradient(90deg, #a1a1aa 0px 1px, transparent 1px 3px); background-size: 6px 6px;"></div>
  <!-- Silver sheen highlight -->
  <div class="absolute inset-0 opacity-30" style="background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.7) 50%, transparent 100%);"></div>

  <!-- Main Footer -->
  <div class="container-wide py-16 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-10">

      <!-- Brand Column -->
      <div class="col-span-2">
        <a href="/" class="inline-flex items-center gap-3 mb-6 group">
          <div class="w-10 h-10 bg-gradient-to-br from-slate-800 to-slate-900 flex items-center justify-center shadow-lg group-hover:shadow-slate-900/30 group-hover:scale-105 transition-all duration-300" style="border-radius: 0;">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18M5 21V7l8-4 8 4v14M8 21v-4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4"/>
            </svg>
          </div>
          <div>
            <span class="block text-lg font-semibold text-slate-900">Steel Cap</span>
            <span class="block text-xs text-slate-600">Commercial</span>
          </div>
        </a>

        <p class="text-slate-600 text-sm mb-6 max-w-xs leading-relaxed">
          Your 2026 playbook for integrated facility and IT service solutions.
          Driving efficiency, safety, and growth across Australia.
        </p>

        <!-- Social Links with hover effects -->
        <div class="flex items-center gap-3">
          <a href="#" class="w-10 h-10 bg-white border border-slate-300 hover:bg-slate-900 hover:border-slate-900 flex items-center justify-center text-slate-700 hover:text-white transition-all duration-300 group hover:scale-110 hover:-translate-y-1 shadow-sm" aria-label="LinkedIn" style="border-radius: 0;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white border border-slate-300 hover:bg-slate-900 hover:border-slate-900 flex items-center justify-center text-slate-700 hover:text-white transition-all duration-300 group hover:scale-110 hover:-translate-y-1 shadow-sm" aria-label="Twitter" style="border-radius: 0;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3 .1 4 .5 0 0 .1 0 .1-.1-1-3-2-5-2-5 3.4 2.2 4.8 7 4.9 8.3-.3.1-.6.1-.9.1z"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white border border-slate-300 hover:bg-slate-900 hover:border-slate-900 flex items-center justify-center text-slate-700 hover:text-white transition-all duration-300 group hover:scale-110 hover:-translate-y-1 shadow-sm" aria-label="Facebook" style="border-radius: 0;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white border border-slate-300 hover:bg-slate-900 hover:border-slate-900 flex items-center justify-center text-slate-700 hover:text-white transition-all duration-300 group hover:scale-110 hover:-translate-y-1 shadow-sm" aria-label="Instagram" style="border-radius: 0;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="mailto:contact@steelcapcommercial.com" class="w-10 h-10 bg-white border border-slate-300 hover:bg-slate-900 hover:border-slate-900 flex items-center justify-center text-slate-700 hover:text-white transition-all duration-300 group hover:scale-110 hover:-translate-y-1 shadow-sm" aria-label="Email" style="border-radius: 0;">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Footer Links -->
      {footerSections.map((section) => (
        <div>
          <h4 class="font-semibold text-sm mb-4 text-slate-900">
            {section.title}
          </h4>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-slate-600 hover:text-slate-900 text-sm
                         transition-all duration-300
                         inline-flex items-center gap-1
                         group hover:translate-x-1"
                >
                  {link.name}
                  <svg class="w-3 h-3 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-slate-300/50 relative z-10" style="background: linear-gradient(135deg, #c4c4c8 0%, #d4d4d8 50%, #c4c4c8 100%);">
    <div class="container-wide py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">

        <!-- Copyright -->
        <p class="text-slate-700 text-sm font-medium">
          © 2026 Steel Cap Commercial. All rights reserved.
        </p>

        <!-- Location -->
        <div class="flex items-center gap-2 text-slate-700 text-sm font-medium">
          <svg class="w-4 h-4 text-slate-800" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>Australia-wide</span>
        </div>

        <!-- Back to top -->
        <button
          id="back-to-top"
          class="flex items-center gap-2 text-slate-700 hover:text-slate-900 text-sm font-medium
                 transition-all duration-300 group
                 hover:translate-y-0.5"
        >
          <span>Back to top</span>
          <svg class="w-4 h-4 text-slate-700 group-hover:-translate-y-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 15l-6-6-6 6"/>
          </svg>
        </button>

      </div>
    </div>
  </div>
</footer>

<script>
  // Back to top button with smooth scroll
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
