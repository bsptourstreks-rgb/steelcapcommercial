---
/**
 * Hero Section - Silver Circuit Board Theme
 * Central CPU CHIP with connected modules and electric current
 */
---

<section id="hero" class="relative min-h-[600px] flex items-center overflow-hidden" style="background: linear-gradient(135deg, #d4d4d8 0%, #e4e4e7 30%, #f4f4f5 50%, #e4e4e7 70%, #d4d4d8 100%);">
  <!-- Pure metallic silver mesh overlay -->
  <div class="absolute inset-0 opacity-15" style="background-image: repeating-linear-gradient(0deg, #a1a1aa 0px 1px, transparent 1px 3px), repeating-linear-gradient(90deg, #a1a1aa 0px 1px, transparent 1px 3px); background-size: 6px 6px;"></div>
  <!-- Silver sheen highlight -->
  <div class="absolute inset-0 opacity-30" style="background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.7) 50%, transparent 100%);"></div>

  <!-- Circuit Board with Angled Traces -->
  <div class="absolute inset-0 opacity-40">
    <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="silverTrace" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#71717a"/>
          <stop offset="50%" style="stop-color:#a1a1aa"/>
          <stop offset="100%" style="stop-color:#71717a"/>
        </linearGradient>
        <linearGradient id="pulseGrad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#f59e0b;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#fbbf24;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:0"/>
        </linearGradient>
        <filter id="pulseGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="3"/>
        </filter>
        <filter id="circuitShadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="1" dy="1" stdDeviation="1" flood-color="#000" flood-opacity="0.2"/>
        </filter>
        <!-- Apple-style premium glass shadow -->
        <filter id="glassShadow" x="-50%" y="-50%" width="200%" height="200%">
          <feDropShadow dx="0" dy="4" stdDeviation="12" flood-color="#0" flood-opacity="0.08"/>
          <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#0" flood-opacity="0.04"/>
          <feDropShadow dx="0" dy="0" stdDeviation="1" flood-color="#fff" flood-opacity="0.8"/>
        </filter>
      </defs>

      <!-- Background circuit traces -->
      <g stroke="url(#silverTrace)" stroke-width="2" fill="none" filter="url(#circuitShadow)" stroke-linecap="round" stroke-linejoin="round">
        <path d="M-50 60 L100 60 L130 90 L250 90 L280 120 L400 120"/>
        <path d="M450 80 L520 80 L550 50 L680 50 L710 80 L850 80"/>
        <path d="M900 140 L980 140 L1010 170 L1150 170 L1180 200 L1320 200"/>
        <path d="M400 120 L430 150 L430 220 L360 220"/>
        <path d="M850 80 L880 110 L880 180 L810 180"/>
        <path d="M-50 300 L50 300 L80 270 L180 270 L210 240 L330 240"/>
        <path d="M400 280 L470 280 L500 310 L620 310"/>
      </g>

      <g fill="#94a3b8" stroke="#64748b" stroke-width="1">
        <circle cx="100" cy="60" r="7"/>
        <circle cx="250" cy="90" r="6"/>
        <circle cx="400" cy="120" r="7"/>
        <circle cx="520" cy="80" r="7"/>
        <circle cx="680" cy="50" r="6"/>
        <circle cx="850" cy="80" r="7"/>
        <circle cx="980" cy="140" r="7"/>
        <circle cx="1150" cy="170" r="6"/>
        <circle cx="1320" cy="200" r="7"/>
      </g>

      <!-- Animated Pulses on background circuits -->
      <g stroke="url(#pulseGrad)" stroke-width="3" fill="none" filter="url(#pulseGlow)" stroke-linecap="round">
        <path d="M-50 60 L100 60 L130 90 L250 90 L280 120">
          <animate attributeName="stroke-dasharray" values="0,600;600,0" dur="3s" repeatCount="indefinite"/>
        </path>
        <path d="M450 80 L520 80 L550 50 L680 50 L710 80">
          <animate attributeName="stroke-dasharray" values="0,500;500,0" dur="2.5s" repeatCount="indefinite"/>
        </path>
      </g>
    </svg>
  </div>

  <!-- Subtle mesh overlay -->
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #64748b 1px, transparent 1px); background-size: 24px 24px;"></div>

  <!-- Content -->
  <div class="container-center relative z-10 py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- LEFT: Content -->
      <div class="max-w-2xl">
        <div class="hero-reveal inline-flex items-center gap-2 px-4 py-2 rounded-none
                    bg-white/80 border border-slate-300/50
                    text-slate-700 text-xs font-semibold uppercase tracking-widest mb-8
                    backdrop-blur-xl shadow-lg">
          <span class="w-1.5 h-1.5 rounded-none bg-amber-500 animate-pulse"></span>
          Facility & IT Solutions
        </div>

        <h1 class="hero-reveal stagger-1 mb-6 leading-tight tracking-tight">
          <span class="premium-title-3d block text-5xl md:text-6xl font-bold">Your Operations,</span>
          <span class="premium-title-3d-gradient block text-5xl md:text-6xl font-bold mt-2">
            Optimized.
          </span>
        </h1>

        <p class="hero-reveal stagger-2 text-slate-600 text-lg mb-10 leading-relaxed max-w-lg">
          Integrated facility management and enterprise IT services.
          One partner for your entire infrastructure.
        </p>

        <div class="hero-reveal stagger-3 flex flex-wrap items-center gap-4">
          <a href="#contact" class="group relative inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white rounded-none font-semibold text-sm hover:bg-slate-800 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-slate-900/20">
            Get Started
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#services" class="inline-flex items-center gap-2 px-6 py-3 text-slate-600 text-sm font-medium hover:text-slate-900 transition-colors">
            View Services
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- RIGHT: Alien Tech SCC Chip with Modules -->
      <div class="relative hero-reveal stagger-2">
        <div class="relative w-full aspect-square max-w-5xl mx-auto" style="padding-top: 8px;">
          <svg class="absolute inset-0 w-full h-full" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <!-- Alien glow gradients -->
              <radialGradient id="alienGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#0ea5e9;stop-opacity:0.3"/>
                <stop offset="100%" style="stop-color:#0ea5e9;stop-opacity:0"/>
              </radialGradient>
              <radialGradient id="cyanGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#22d3ee;stop-opacity:0.5"/>
                <stop offset="100%" style="stop-color:#22d3ee;stop-opacity:0"/>
              </radialGradient>
              <filter id="alienBlur" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="2"/>
              </filter>

              <!-- Premium Apple-style dark gradient -->
              <linearGradient id="premiumDark" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#1c1c1e"/>
                <stop offset="50%" style="stop-color:#2c2c2e"/>
                <stop offset="100%" style="stop-color:#1c1c1e"/>
              </linearGradient>

              <!-- Glassmorphism overlay gradient -->
              <linearGradient id="glassSheen" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.15"/>
                <stop offset="50%" style="stop-color:#ffffff;stop-opacity:0.05"/>
                <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0.1"/>
              </linearGradient>

              <!-- Subtle inner glow -->
              <radialGradient id="innerGlow" cx="30%" cy="30%" r="70%">
                <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.08"/>
                <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0"/>
              </radialGradient>

              <!-- Premium chip gradient -->
              <linearGradient id="chipGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#252528"/>
                <stop offset="30%" style="stop-color:#323236"/>
                <stop offset="70%" style="stop-color:#2c2c2e"/>
                <stop offset="100%" style="stop-color:#1c1c1e"/>
              </linearGradient>

              <!-- Apple-style soft shadow -->
              <filter id="appleShadow" x="-50%" y="-50%" width="200%" height="200%">
                <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#000" flood-opacity="0.3"/>
                <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#000" flood-opacity="0.2"/>
                <feDropShadow dx="0" dy="0" stdDeviation="1" flood-color="#fff" flood-opacity="0.1"/>
              </filter>

              <!-- Glass blur filter -->
              <filter id="glassBlur">
                <feGaussianBlur stdDeviation="1"/>
              </filter>
            </defs>

            <!-- Background glow -->
            <circle cx="300" cy="300" r="200" fill="url(#alienGlow)"/>

            <!-- MAIN SCC CHIP - Premium Apple-Style Dark -->
            <g transform="translate(300, 300)" filter="url(#appleShadow)">
              <!-- Outer rotating ring -->
              <circle r="75" fill="none" stroke="#0ea5e9" stroke-width="1" stroke-dasharray="10 5" opacity="0.5">
                <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="20s" repeatCount="indefinite"/>
              </circle>

              <!-- Second ring - counter rotating -->
              <circle r="68" fill="none" stroke="#22d3ee" stroke-width="1" stroke-dasharray="5 3" opacity="0.4">
                <animateTransform attributeName="transform" type="rotate" from="360 0 0" to="0 0 0" dur="15s" repeatCount="indefinite"/>
              </circle>

              <!-- Main chip body with premium gradient -->
              <rect x="-55" y="-55" width="110" height="110" fill="url(#chipGradient)" stroke="#3a3a3c" stroke-width="1.5">
                <animate attributeName="stroke-width" values="1.5;2.5;1.5" dur="2s" repeatCount="indefinite"/>
              </rect>

              <!-- Inner glow overlay -->
              <rect x="-55" y="-55" width="110" height="110" fill="url(#innerGlow)"/>

              <!-- Glass sheen overlay -->
              <rect x="-55" y="-55" width="110" height="110" fill="url(#glassSheen)"/>

              <!-- Inner circuit pattern -->
              <g stroke="#0ea5e9" stroke-width="1" fill="none" opacity="0.4">
                <rect x="-40" y="-40" width="80" height="80" stroke-dasharray="3 2"/>
                <rect x="-30" y="-30" width="60" height="60" stroke-dasharray="2 2"/>
                <rect x="-20" y="-20" width="40" height="40" stroke-dasharray="2 1"/>
              </g>

              <!-- SCC Text -->
              <text x="0" y="5" text-anchor="middle" fill="#22d3ee" font-size="16" font-weight="bold" font-family="monospace">SCC</text>
              <text x="0" y="20" text-anchor="middle" fill="#0ea5e9" font-size="6" font-family="monospace" opacity="0.8">CORE HUB</text>

              <!-- Pulsing core -->
              <circle r="8" fill="#0ea5e9">
                <animate attributeName="opacity" values="0.3;1;0.3" dur="1s" repeatCount="indefinite"/>
                <animate attributeName="r" values="8;12;8" dur="1s" repeatCount="indefinite"/>
              </circle>
            </g>

            <!-- ORBITING MODULES GROUP - Circular Animation around SCC chip -->
            <!-- Outer group: Position at center -->
            <g transform="translate(300, 300)">
              <!-- Inner group: Handle rotation -->
              <g>
                <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="30s" repeatCount="indefinite"/>

              <!-- MODULE 1: TOP - Cloud Service - Electric Blue -->
              <!-- Position: 230px from center (radius of orbit) -->
              <g transform="translate(0, -230)" class="hover-module" filter="url(#appleShadow)">
                <!-- Counter-rotate to keep text upright -->
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="-360 0 0" dur="30s" repeatCount="indefinite"/>
                  <circle r="40" fill="url(#premiumDark)" stroke="#00d4ff" stroke-width="2.5">
                    <animate attributeName="r" values="40;44;40" dur="2s" repeatCount="indefinite"/>
                    <animate attributeName="stroke-width" values="2.5;3.5;2.5" dur="2s" repeatCount="indefinite"/>
                  </circle>
                  <circle r="35" fill="none" stroke="#00d4ff" stroke-width="1" stroke-dasharray="4 2" opacity="0.6">
                    <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="10s" repeatCount="indefinite"/>
                  </circle>
                  <!-- Inner glow -->
                  <circle r="40" fill="url(#innerGlow)"/>
                  <!-- Glass sheen -->
                  <circle r="40" fill="url(#glassSheen)"/>
                  <!-- Premium glow effect -->
                  <circle r="40" fill="none" stroke="#00d4ff" stroke-width="4" opacity="0.3">
                    <animate attributeName="opacity" values="0.3;0.6;0.3" dur="2s" repeatCount="indefinite"/>
                  </circle>
                  <text x="0" y="2" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">CLOUD</text>
                  <text x="0" y="14" text-anchor="middle" fill="#00d4ff" font-size="6" font-family="monospace">INFRASTRUCTURE</text>
                </g>
              </g>

              <!-- MODULE 2: RIGHT - Facility Service - Emerald Green -->
              <g transform="translate(230, 0)" class="hover-module" filter="url(#appleShadow)">
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="-360 0 0" dur="30s" repeatCount="indefinite"/>
                  <circle r="40" fill="url(#premiumDark)" stroke="#00ff88" stroke-width="2.5">
                    <animate attributeName="r" values="40;44;40" dur="2s" repeatCount="indefinite" begin="0.5s"/>
                    <animate attributeName="stroke-width" values="2.5;3.5;2.5" dur="2s" repeatCount="indefinite" begin="0.5s"/>
                  </circle>
                  <circle r="35" fill="none" stroke="#00ff88" stroke-width="1" stroke-dasharray="4 2" opacity="0.6">
                    <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="10s" repeatCount="indefinite"/>
                  </circle>
                  <circle r="40" fill="url(#innerGlow)"/>
                  <circle r="40" fill="url(#glassSheen)"/>
                  <circle r="40" fill="none" stroke="#00ff88" stroke-width="4" opacity="0.3">
                    <animate attributeName="opacity" values="0.3;0.6;0.3" dur="2s" repeatCount="indefinite" begin="0.5s"/>
                  </circle>
                  <text x="0" y="2" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">FACILITY</text>
                  <text x="0" y="14" text-anchor="middle" fill="#00ff88" font-size="6" font-family="monospace">MANAGEMENT</text>
                </g>
              </g>

              <!-- MODULE 3: BOTTOM - IT Service - Gold/Amber -->
              <g transform="translate(0, 230)" class="hover-module" filter="url(#appleShadow)">
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="-360 0 0" dur="30s" repeatCount="indefinite"/>
                  <circle r="40" fill="url(#premiumDark)" stroke="#ffd700" stroke-width="2.5">
                    <animate attributeName="r" values="40;44;40" dur="2s" repeatCount="indefinite" begin="0.3s"/>
                    <animate attributeName="stroke-width" values="2.5;3.5;2.5" dur="2s" repeatCount="indefinite" begin="0.3s"/>
                  </circle>
                  <circle r="35" fill="none" stroke="#ffd700" stroke-width="1" stroke-dasharray="4 2" opacity="0.6">
                    <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="10s" repeatCount="indefinite"/>
                  </circle>
                  <circle r="40" fill="url(#innerGlow)"/>
                  <circle r="40" fill="url(#glassSheen)"/>
                  <circle r="40" fill="none" stroke="#ffd700" stroke-width="4" opacity="0.3">
                    <animate attributeName="opacity" values="0.3;0.6;0.3" dur="2s" repeatCount="indefinite" begin="0.3s"/>
                  </circle>
                  <text x="0" y="2" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">IT</text>
                  <text x="0" y="14" text-anchor="middle" fill="#ffd700" font-size="6" font-family="monospace">SOLUTIONS</text>
                </g>
              </g>

              <!-- MODULE 4: LEFT - Industry Service - Rose Pink -->
              <g transform="translate(-230, 0)" class="hover-module" filter="url(#appleShadow)">
                <g>
                  <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="-360 0 0" dur="30s" repeatCount="indefinite"/>
                  <circle r="40" fill="url(#premiumDark)" stroke="#ff6b9d" stroke-width="2.5">
                    <animate attributeName="r" values="40;44;40" dur="2s" repeatCount="indefinite" begin="0.7s"/>
                    <animate attributeName="stroke-width" values="2.5;3.5;2.5" dur="2s" repeatCount="indefinite" begin="0.7s"/>
                  </circle>
                  <circle r="35" fill="none" stroke="#ff6b9d" stroke-width="1" stroke-dasharray="4 2" opacity="0.6">
                    <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="10s" repeatCount="indefinite"/>
                  </circle>
                  <circle r="40" fill="url(#innerGlow)"/>
                  <circle r="40" fill="url(#glassSheen)"/>
                  <circle r="40" fill="none" stroke="#ff6b9d" stroke-width="4" opacity="0.3">
                    <animate attributeName="opacity" values="0.3;0.6;0.3" dur="2s" repeatCount="indefinite" begin="0.7s"/>
                  </circle>
                  <text x="0" y="2" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">INDUSTRY</text>
                  <text x="0" y="14" text-anchor="middle" fill="#ff6b9d" font-size="6" font-family="monospace">EXPERTISE</text>
                </g>
              </g>
              <!-- Close inner rotation group -->
              </g>
            <!-- Close outer positioning group -->
            </g>
          </svg>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes hero-reveal { to { opacity: 1; transform: translateY(0); } }
  .hero-reveal { opacity: 0; transform: translateY(30px); animation: hero-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .stagger-1 { animation-delay: 0.1s; }
  .stagger-2 { animation-delay: 0.2s; }
  .stagger-3 { animation-delay: 0.3s; }

  /* Premium 3D Title Effect */
  .premium-title-3d {
    color: #0f172a;
    text-shadow:
      0 1px 0 #64748b,
      0 2px 0 #475569,
      0 3px 0 #334155,
      0 4px 0 #1e293b,
      0 5px 6px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(251, 191, 36, 0.2);
    animation: titleShimmer 4s ease-in-out infinite;
    position: relative;
  }

  @keyframes titleShimmer {
    0%, 100% {
      text-shadow:
        0 1px 0 #64748b,
        0 2px 0 #475569,
        0 3px 0 #334155,
        0 4px 0 #1e293b,
        0 5px 6px rgba(0, 0, 0, 0.3),
        0 0 20px rgba(251, 191, 36, 0.2);
    }
    50% {
      text-shadow:
        0 1px 0 #64748b,
        0 2px 0 #475569,
        0 3px 0 #334155,
        0 4px 0 #1e293b,
        0 5px 6px rgba(0, 0, 0, 0.3),
        0 0 30px rgba(251, 191, 36, 0.4),
        0 0 40px rgba(245, 158, 11, 0.2);
    }
  }

  /* Premium Gradient Title with Animation */
  .premium-title-3d-gradient {
    background: linear-gradient(
      135deg,
      #f59e0b 0%,
      #fbbf24 15%,
      #fcd34d 25%,
      #fbbf24 35%,
      #f59e0b 50%,
      #d97706 65%,
      #f59e0b 75%,
      #fbbf24 85%,
      #f59e0b 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientFlow 5s ease infinite;
    filter: drop-shadow(0 2px 0 #d97706)
            drop-shadow(0 4px 0 #b45309)
            drop-shadow(0 6px 8px rgba(0, 0, 0, 0.3));
  }

  @keyframes gradientFlow {
    0% { background-position: 0% center; }
    50% { background-position: 100% center; }
    100% { background-position: 0% center; }
  }
</style>

<script>
  // Pure CSS/SVG animations
</script>
