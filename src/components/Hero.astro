---
/**
 * Hero Section - Silver Circuit Board Theme
 * Central CPU CHIP with connected modules and electric current
 */
---

<section id="hero" class="relative min-h-[600px] flex items-center overflow-hidden" style="background: linear-gradient(135deg, #d4d4d8 0%, #e4e4e7 30%, #f4f4f5 50%, #e4e4e7 70%, #d4d4d8 100%);">
  <!-- Pure metallic silver mesh overlay -->
  <div class="absolute inset-0 opacity-15" style="background-image: repeating-linear-gradient(0deg, #a1a1aa 0px 1px, transparent 1px 3px), repeating-linear-gradient(90deg, #a1a1aa 0px 1px, transparent 1px 3px); background-size: 6px 6px;"></div>
  <!-- Silver sheen highlight -->
  <div class="absolute inset-0 opacity-30" style="background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.7) 50%, transparent 100%);"></div>

  <!-- Circuit Board with Angled Traces -->
  <div class="absolute inset-0 opacity-40">
    <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="silverTrace" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#71717a"/>
          <stop offset="50%" style="stop-color:#a1a1aa"/>
          <stop offset="100%" style="stop-color:#71717a"/>
        </linearGradient>
        <linearGradient id="pulseGrad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" style="stop-color:#f59e0b;stop-opacity:0"/>
          <stop offset="50%" style="stop-color:#fbbf24;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:0"/>
        </linearGradient>
        <filter id="pulseGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="3"/>
        </filter>
        <filter id="circuitShadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="1" dy="1" stdDeviation="1" flood-color="#000" flood-opacity="0.2"/>
        </filter>
        <!-- Apple-style premium glass shadow -->
        <filter id="glassShadow" x="-50%" y="-50%" width="200%" height="200%">
          <feDropShadow dx="0" dy="4" stdDeviation="12" flood-color="#0" flood-opacity="0.08"/>
          <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#0" flood-opacity="0.04"/>
          <feDropShadow dx="0" dy="0" stdDeviation="1" flood-color="#fff" flood-opacity="0.8"/>
        </filter>
      </defs>

      <!-- Background circuit traces -->
      <g stroke="url(#silverTrace)" stroke-width="2" fill="none" filter="url(#circuitShadow)" stroke-linecap="round" stroke-linejoin="round">
        <path d="M-50 60 L100 60 L130 90 L250 90 L280 120 L400 120"/>
        <path d="M450 80 L520 80 L550 50 L680 50 L710 80 L850 80"/>
        <path d="M900 140 L980 140 L1010 170 L1150 170 L1180 200 L1320 200"/>
        <path d="M400 120 L430 150 L430 220 L360 220"/>
        <path d="M850 80 L880 110 L880 180 L810 180"/>
        <path d="M-50 300 L50 300 L80 270 L180 270 L210 240 L330 240"/>
        <path d="M400 280 L470 280 L500 310 L620 310"/>
      </g>

      <g fill="#94a3b8" stroke="#64748b" stroke-width="1">
        <circle cx="100" cy="60" r="7"/>
        <circle cx="250" cy="90" r="6"/>
        <circle cx="400" cy="120" r="7"/>
        <circle cx="520" cy="80" r="7"/>
        <circle cx="680" cy="50" r="6"/>
        <circle cx="850" cy="80" r="7"/>
        <circle cx="980" cy="140" r="7"/>
        <circle cx="1150" cy="170" r="6"/>
        <circle cx="1320" cy="200" r="7"/>
      </g>

      <!-- Animated Pulses on background circuits -->
      <g stroke="url(#pulseGrad)" stroke-width="3" fill="none" filter="url(#pulseGlow)" stroke-linecap="round">
        <path d="M-50 60 L100 60 L130 90 L250 90 L280 120">
          <animate attributeName="stroke-dasharray" values="0,600;600,0" dur="3s" repeatCount="indefinite"/>
        </path>
        <path d="M450 80 L520 80 L550 50 L680 50 L710 80">
          <animate attributeName="stroke-dasharray" values="0,500;500,0" dur="2.5s" repeatCount="indefinite"/>
        </path>
      </g>
    </svg>
  </div>

  <!-- Subtle mesh overlay -->
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #64748b 1px, transparent 1px); background-size: 24px 24px;"></div>

  <!-- Content -->
  <div class="container-center relative z-10 py-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- LEFT: Content -->
      <div class="max-w-2xl">
        <div class="hero-reveal inline-flex items-center gap-2 px-4 py-2 rounded-none
                    bg-white/80 border border-slate-300/50
                    text-slate-700 text-xs font-semibold uppercase tracking-widest mb-8
                    backdrop-blur-xl shadow-lg">
          <span class="w-1.5 h-1.5 rounded-none bg-amber-500 animate-pulse"></span>
          Facility & IT Solutions
        </div>

        <h1 class="hero-reveal stagger-1 mb-6 leading-tight tracking-tight">
          <span class="premium-title-3d block text-5xl md:text-6xl font-bold">Your Operations,</span>
          <span class="premium-title-3d-gradient block text-5xl md:text-6xl font-bold mt-2">
            Optimized.
          </span>
        </h1>

        <p class="hero-reveal stagger-2 text-slate-600 text-lg mb-10 leading-relaxed max-w-lg">
          Integrated facility management and enterprise IT services.
          One partner for your entire infrastructure.
        </p>

        <div class="hero-reveal stagger-3 flex flex-wrap items-center gap-4">
          <a href="#contact" class="group relative inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white rounded-none font-semibold text-sm hover:bg-slate-800 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-slate-900/20">
            Get Started
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#services" class="inline-flex items-center gap-2 px-6 py-3 text-slate-600 text-sm font-medium hover:text-slate-900 transition-colors">
            View Services
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- RIGHT: CPU CHIP with Connected Modules -->
      <div class="relative hero-reveal stagger-2">
        <div class="relative w-full aspect-square max-w-md mx-auto" style="padding-top: 8px;">
          <!-- Glow backdrop -->
          <div class="absolute inset-0 bg-gradient-to-br from-amber-400/20 via-orange-300/10 to-amber-400/20 rounded-full blur-3xl"></div>

          <!-- Motherboard -->
          <div class="relative h-full">
            <svg class="absolute inset-0 w-full h-full" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
              <defs>
                <!-- Gold pins gradient -->
                <linearGradient id="goldPin" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" style="stop-color:#fcd34d"/>
                  <stop offset="50%" style="stop-color:#f59e0b"/>
                  <stop offset="100%" style="stop-color:#d97706"/>
                </linearGradient>

                <!-- Electric pulse from center -->
                <radialGradient id="centerPulse">
                  <stop offset="0%" style="stop-color:#fbbf24;stop-opacity:1"/>
                  <stop offset="50%" style="stop-color:#f59e0b;stop-opacity:0.5"/>
                  <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:0"/>
                </radialGradient>
              </defs>

              <!-- Connection traces from chip corners to modules -->
              <g stroke="url(#silverTrace)" stroke-width="3" fill="none" stroke-linecap="round">
                <!-- Top-left diagonal trace to Cloud -->
                <path d="M145 145 L80 80"/>
                <!-- Top-right diagonal trace to IT & Security -->
                <path d="M255 145 L320 80"/>
                <!-- Bottom-left diagonal trace to Facility -->
                <path d="M145 255 L80 320"/>
                <!-- Bottom-right diagonal trace to Energy -->
                <path d="M255 255 L320 320"/>
              </g>

              <!-- Animated electric current flowing from corners -->
              <g>
                <!-- Top-left pulse to Cloud -->
                <circle r="0" fill="url(#centerPulse)">
                  <animateMotion dur="1.5s" repeatCount="indefinite" path="M145 145 L80 80"/>
                </circle>
                <!-- Top-right pulse to IT & Security -->
                <circle r="0" fill="url(#centerPulse)">
                  <animateMotion dur="1.8s" repeatCount="indefinite" path="M255 145 L320 80"/>
                </circle>
                <!-- Bottom-left pulse to Facility -->
                <circle r="0" fill="url(#centerPulse)">
                  <animateMotion dur="1.6s" repeatCount="indefinite" path="M145 255 L80 320"/>
                </circle>
                <!-- Bottom-right pulse to Energy -->
                <circle r="0" fill="url(#centerPulse)">
                  <animateMotion dur="2s" repeatCount="indefinite" path="M255 255 L320 320"/>
                </circle>
              </g>

              <!-- Gold pins at trace ends -->
              <g fill="url(#goldPin)">
                <!-- Top-left pins -->
                <rect x="78" y="72" width="8" height="3" rx="0"/>
                <rect x="78" y="78" width="8" height="3" rx="0"/>
                <!-- Top-right pins -->
                <rect x="314" y="72" width="8" height="3" rx="0"/>
                <rect x="314" y="78" width="8" height="3" rx="0"/>
                <!-- Bottom-left pins -->
                <rect x="78" y="319" width="8" height="3" rx="0"/>
                <rect x="78" y="325" width="8" height="3" rx="0"/>
                <!-- Bottom-right pins -->
                <rect x="314" y="319" width="8" height="3" rx="0"/>
                <rect x="314" y="325" width="8" height="3" rx="0"/>
              </g>

              <!-- Central CPU CHIP - Premium Electric Animation -->
              <g transform="translate(200, 200)">
                <!-- Outer electric ring - current flowing around chip -->
                <g stroke="url(#pulseGrad)" stroke-width="2" fill="none" filter="url(#pulseGlow)">
                  <rect x="-62" y="-62" width="124" height="124" rx="0" stroke-dasharray="8 4" opacity="0.8">
                    <animateTransform attributeName="transform" type="rotate" from="0 0 0" to="360 0 0" dur="8s" repeatCount="indefinite"/>
                  </rect>
                  <!-- Second ring - counter rotating -->
                  <rect x="-58" y="-58" width="116" height="116" rx="0" stroke-dasharray="4 8" opacity="0.5">
                    <animateTransform attributeName="transform" type="rotate" from="360 0 0" to="0 0 0" dur="6s" repeatCount="indefinite"/>
                  </rect>
                </g>

                <!-- Electric sparks at corners -->
                <g>
                  <circle cx="-60" cy="-60" r="3" fill="#fbbf24" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite" begin="0s"/>
                  </circle>
                  <circle cx="60" cy="-60" r="3" fill="#fbbf24" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite" begin="0.25s"/>
                  </circle>
                  <circle cx="60" cy="60" r="3" fill="#fbbf24" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite" begin="0.5s"/>
                  </circle>
                  <circle cx="-60" cy="60" r="3" fill="#fbbf24" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite" begin="0.75s"/>
                  </circle>
                </g>

                <!-- Chip body - sharp edges with glow -->
                <rect x="-55" y="-55" width="110" height="110" rx="0" fill="#1e293b" stroke="#475569" stroke-width="2">
                  <animate attributeName="stroke" values="#475569;#fbbf24;#475569" dur="2s" repeatCount="indefinite"/>
                </rect>
                <rect x="-50" y="-50" width="100" height="100" rx="0" fill="#0f172a"/>

                <!-- Internal circuit traces - animated -->
                <g stroke="#fbbf24" stroke-width="1" fill="none" opacity="0.6">
                  <!-- Horizontal traces -->
                  <path d="M-40 -30 L40 -30" stroke-dasharray="40">
                    <animate attributeName="stroke-dashoffset" values="0;-80" dur="1.5s" repeatCount="indefinite"/>
                  </path>
                  <path d="M-40 0 L40 0" stroke-dasharray="40">
                    <animate attributeName="stroke-dashoffset" values="0;-80" dur="1.5s" repeatCount="indefinite" begin="0.3s"/>
                  </path>
                  <path d="M-40 30 L40 30" stroke-dasharray="40">
                    <animate attributeName="stroke-dashoffset" values="0;-80" dur="1.5s" repeatCount="indefinite" begin="0.6s"/>
                  </path>
                  <!-- Vertical traces -->
                  <path d="M-30 -40 L-30 40" stroke-dasharray="40">
                    <animate attributeName="stroke-dashoffset" values="0;-80" dur="1.5s" repeatCount="indefinite" begin="0.2s"/>
                  </path>
                  <path d="M0 -40 L0 40" stroke-dasharray="40">
                    <animate attributeName="stroke-dashoffset" values="0;-80" dur="1.5s" repeatCount="indefinite" begin="0.5s"/>
                  </path>
                  <path d="M30 -40 L30 40" stroke-dasharray="40">
                    <animate attributeName="stroke-dashoffset" values="0;-80" dur="1.5s" repeatCount="indefinite" begin="0.8s"/>
                  </path>
                </g>

                <!-- Chip inner detail - sharp -->
                <rect x="-38" y="-38" width="76" height="76" rx="0" fill="#1e293b" stroke="#fbbf24" stroke-width="1" opacity="0.8">
                  <animate attributeName="opacity" values="0.5;1;0.5" dur="2s" repeatCount="indefinite"/>
                </rect>
                <rect x="-28" y="-28" width="56" height="56" rx="0" fill="#334155"/>

                <!-- Core - sharp with electric pulse -->
                <rect x="-18" y="-18" width="36" height="36" rx="0" fill="#475569"/>
                <rect x="-12" y="-12" width="24" height="24" rx="0" fill="#64748b"/>

                <!-- Animated core glow -->
                <rect x="-14" y="-14" width="28" height="28" rx="0" fill="none" stroke="#fbbf24" stroke-width="2" opacity="0">
                  <animate attributeName="opacity" values="1;0.3;1" dur="1s" repeatCount="indefinite"/>
                  <animate attributeName="rx" values="14;18;14" dur="1s" repeatCount="indefinite"/>
                  <animate attributeName="ry" values="14;18;14" dur="1s" repeatCount="indefinite"/>
                </rect>
              </g>

              <!-- CPU pins on chip - rendered before text -->
              <g transform="translate(200, 200)" fill="#fcd34d">
                <!-- Top pins -->
                <rect x="-45" y="-58" width="8" height="5" rx="0"/>
                <rect x="-22" y="-58" width="8" height="5" rx="0"/>
                <rect x="2" y="-58" width="8" height="5" rx="0"/>
                <rect x="25" y="-58" width="8" height="5" rx="0"/>
                <rect x="48" y="-58" width="8" height="5" rx="0"/>
                <!-- Bottom pins -->
                <rect x="-45" y="53" width="8" height="5" rx="0"/>
                <rect x="-22" y="53" width="8" height="5" rx="0"/>
                <rect x="2" y="53" width="8" height="5" rx="0"/>
                <rect x="25" y="53" width="8" height="5" rx="0"/>
                <rect x="48" y="53" width="8" height="5" rx="0"/>
                <!-- Left pins -->
                <rect x="-58" y="-35" width="5" height="8" rx="0"/>
                <rect x="-58" y="-12" width="5" height="8" rx="0"/>
                <rect x="-58" y="12" width="5" height="8" rx="0"/>
                <rect x="-58" y="35" width="5" height="8" rx="0"/>
                <!-- Right pins -->
                <rect x="53" y="-35" width="5" height="8" rx="0"/>
                <rect x="53" y="-12" width="5" height="8" rx="0"/>
                <rect x="53" y="12" width="5" height="8" rx="0"/>
                <rect x="53" y="35" width="5" height="8" rx="0"/>
              </g>

              <!-- Pulsing core - rendered before text -->
              <g transform="translate(200, 200)">
                <rect x="-10" y="-10" width="20" height="20" rx="0" fill="#f59e0b" opacity="0.8">
                  <animate attributeName="opacity" values="0.4;1;0.4" dur="1s" repeatCount="indefinite"/>
                </rect>
              </g>

              <!-- SCC TEXT LAYER - Topmost, rendered last -->
              <g transform="translate(200, 200)">
                <!-- Electric current flowing through text area -->
                <g stroke="#fbbf24" stroke-width="2" fill="none" filter="url(#pulseGlow)">
                  <!-- Current from left -->
                  <path d="M-40 5 L-25 5" stroke-dasharray="10 5">
                    <animate attributeName="stroke-dashoffset" values="0;-30" dur="0.8s" repeatCount="indefinite"/>
                  </path>
                  <!-- Current from right -->
                  <path d="M40 5 L25 5" stroke-dasharray="10 5">
                    <animate attributeName="stroke-dashoffset" values="0;-30" dur="0.8s" repeatCount="indefinite" begin="0.4s"/>
                  </path>
                  <!-- Current from top -->
                  <path d="M0 -35 L0 -15" stroke-dasharray="10 5">
                    <animate attributeName="stroke-dashoffset" values="0;-30" dur="0.8s" repeatCount="indefinite" begin="0.2s"/>
                  </path>
                  <!-- Current from bottom -->
                  <path d="M0 35 L0 20" stroke-dasharray="10 5">
                    <animate attributeName="stroke-dashoffset" values="0;-30" dur="0.8s" repeatCount="indefinite" begin="0.6s"/>
                  </path>
                </g>

                <!-- Pulsing glow behind text -->
                <ellipse cx="0" cy="3" rx="25" ry="14" fill="url(#centerPulse)" opacity="0.6">
                  <animate attributeName="opacity" values="0.3;0.8;0.3" dur="1.5s" repeatCount="indefinite"/>
                  <animate attributeName="rx" values="23;28;23" dur="1.5s" repeatCount="indefinite"/>
                  <animate attributeName="ry" values="12;17;12" dur="1.5s" repeatCount="indefinite"/>
                </ellipse>

                <!-- Premium animated text - TOP LAYER -->
                <text x="0" y="6" text-anchor="middle" fill="url(#goldText)" font-size="14" font-family="monospace" font-weight="bold" filter="url(#textGlow)" style="z-index: 100;">
                  SCC
                  <animate attributeName="font-size" values="14;15;14" dur="1s" repeatCount="indefinite"/>
                </text>

                <!-- Electric sparks around text - TOP LAYER -->
                <g fill="#fbbf24">
                  <circle cx="-20" cy="3" r="1.5" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="0.6s" repeatCount="indefinite"/>
                  </circle>
                  <circle cx="20" cy="3" r="1.5" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="0.6s" repeatCount="indefinite" begin="0.3s"/>
                  </circle>
                  <circle cx="0" cy="-8" r="1.5" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="0.6s" repeatCount="indefinite" begin="0.15s"/>
                  </circle>
                  <circle cx="0" cy="14" r="1.5" opacity="0">
                    <animate attributeName="opacity" values="1;0;1" dur="0.6s" repeatCount="indefinite" begin="0.45s"/>
                  </circle>
                </g>

              <g transform="translate(80, 80)"><rect x="-50" y="-22" width="100" height="44" fill="#ff0000"/><text x="0" y="2" text-anchor="middle" fill="white" font-size="8">1</text></g>
              <g transform="translate(320, 80)"><rect x="-50" y="-22" width="100" height="44" fill="#00ff00"/><text x="0" y="2" text-anchor="middle" fill="white" font-size="8">2</text></g>
              <g transform="translate(80, 320)"><rect x="-50" y="-22" width="100" height="44" fill="#0000ff"/><text x="0" y="2" text-anchor="middle" fill="white" font-size="8">3</text></g>
              <g transform="translate(320, 320)"><rect x="-50" y="-22" width="100" height="44" fill="#ffff00"/><text x="0" y="2" text-anchor="middle" fill="black" font-size="8">4</text></g>
            </svg>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes hero-reveal { to { opacity: 1; transform: translateY(0); } }
  .hero-reveal { opacity: 0; transform: translateY(30px); animation: hero-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .stagger-1 { animation-delay: 0.1s; }
  .stagger-2 { animation-delay: 0.2s; }
  .stagger-3 { animation-delay: 0.3s; }

  /* Premium 3D Title Effect */
  .premium-title-3d {
    color: #0f172a;
    text-shadow:
      0 1px 0 #64748b,
      0 2px 0 #475569,
      0 3px 0 #334155,
      0 4px 0 #1e293b,
      0 5px 6px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(251, 191, 36, 0.2);
    animation: titleShimmer 4s ease-in-out infinite;
    position: relative;
  }

  @keyframes titleShimmer {
    0%, 100% {
      text-shadow:
        0 1px 0 #64748b,
        0 2px 0 #475569,
        0 3px 0 #334155,
        0 4px 0 #1e293b,
        0 5px 6px rgba(0, 0, 0, 0.3),
        0 0 20px rgba(251, 191, 36, 0.2);
    }
    50% {
      text-shadow:
        0 1px 0 #64748b,
        0 2px 0 #475569,
        0 3px 0 #334155,
        0 4px 0 #1e293b,
        0 5px 6px rgba(0, 0, 0, 0.3),
        0 0 30px rgba(251, 191, 36, 0.4),
        0 0 40px rgba(245, 158, 11, 0.2);
    }
  }

  /* Premium Gradient Title with Animation */
  .premium-title-3d-gradient {
    background: linear-gradient(
      135deg,
      #f59e0b 0%,
      #fbbf24 15%,
      #fcd34d 25%,
      #fbbf24 35%,
      #f59e0b 50%,
      #d97706 65%,
      #f59e0b 75%,
      #fbbf24 85%,
      #f59e0b 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientFlow 5s ease infinite;
    filter: drop-shadow(0 2px 0 #d97706)
            drop-shadow(0 4px 0 #b45309)
            drop-shadow(0 6px 8px rgba(0, 0, 0, 0.3));
  }

  @keyframes gradientFlow {
    0% { background-position: 0% center; }
    50% { background-position: 100% center; }
    100% { background-position: 0% center; }
  }
</style>

<script>
  // Pure CSS/SVG animations
</script>
