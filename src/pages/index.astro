---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import ITServices from '../components/ITServices.astro';
import Industries from '../components/Industries.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Steel Cap Commercial - Integrated Facility & IT Service Solutions">
  <Navigation />
  <main>
    <Hero />
    <TrustBar />
    <Services />
    <ITServices />
    <Industries />
    <CTA />
  </main>
  <Footer />
</Layout>

<style>
  /* Smooth scroll offset for fixed navigation */
  html {
    scroll-padding-top: 100px;
  }
</style>
